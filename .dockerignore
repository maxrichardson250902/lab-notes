# VCS / editor / cache
.git
.gitignore
.github
.vscode
.idea
__pycache__
*.pyc
*.pyo
*.pyd
.pytest_cache
.mypy_cache

# Data — must not be baked into the image (lives in the /data volume at runtime)
data/
*.db
*.db-wal
*.db-shm

# Build artefacts produced inside the container
# index.html is regenerated by `RUN python build.py` in the Dockerfile, so
# whatever the host has would just be overwritten — skip the upload.
static/index.html

# Misc
*.swp
.DS_Store
*.log
